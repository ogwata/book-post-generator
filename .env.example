# --- AI接続設定 ---
# プロバイダー: openai / anthropic / google / custom
AI_PROVIDER=openai
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o
# カスタムプロバイダーの場合のみ指定
# AI_ENDPOINT=https://api.example.com/v1

# --- X (Twitter) API設定 ---
X_API_KEY=your-consumer-key
X_API_SECRET=your-consumer-secret
X_ACCESS_TOKEN=your-access-token
X_ACCESS_TOKEN_SECRET=your-access-token-secret

# --- ログインパスワード ---
LOGIN_PASSWORD=your-shared-password
